{
  "task_name": "math",
  "description": "Math reasoning task with memory system",
  
  "agent": {
    "model_name": "gpt-5-mini",
    "temperature": 0.0,
    "max_tokens": 2000,
    "backend": "openai",
    "base_url": ""
  },
  
  "memory": {
    "use_step_memory": false, 
    "memory_system_name": "bm25",
    "base_url": "http://0.0.0.0:8000",
    "timeout": 300
  },
  
  "env": {
    "env_name": "formal_reasoning_math",
    "base_url": "http://0.0.0.0:8001",
    "timeout": 300,
    "env_config": {
      "model_name": "gpt-5-mini",
      "temperature": 1.0,
      "max_tokens": 4096,
      "backend": "openai",
      "base_url": ""
    }
  },
  
  "task_specific": {
    "max_steps": 20,
    "dataset": {
      "hf_dataset": "ZexueHe/memoryarena",
      "hf_config": "formal_reasoning_math",
      "hf_split": "test"
    }
  },
  
  "output": {
    "output_dir": "./results/math",
    "save_trajectories": true,
    "save_metrics": true
  }
}
